# Local Development Environment
# Copy this file to .env.local and update values for your local development.
# NEVER commit actual .env files with secrets.

# Application environment
APP_ENV=local
FLASK_ENV=development

# Database: Local PostgreSQL 18 via Docker Compose
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_status_local

# API Server (optional - Flask defaults used if not set)
# API_HOST=127.0.0.1
# API_PORT=5000
