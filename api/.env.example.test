# Test Environment
# Copy this file to .env.test and update values for testing.
# NEVER commit actual .env files with secrets.

# Application environment
APP_ENV=test

# Database: Test PostgreSQL 18 (separate from local development)
# Run tests against Docker Compose db or a dedicated test database
DATABASE_URL=postgresql://test:test@localhost:5432/project_status_test

# Test-specific settings
# FLASK_TESTING=true
