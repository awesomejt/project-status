# Stage Environment
# Copy this file to .env.stage and update values for stage deployment.
# NEVER commit actual .env files with secrets.

# Application environment
APP_ENV=stage

# Database: Stage PostgreSQL VM
# Replace with actual stage PostgreSQL VM connection details
# IMPORTANT: Use environment variable injection in deployment, do not hardcode here
DATABASE_URL=postgresql://stage_user:stage_password@stage-postgres.vm.example.com:5432/project_status_stage

# Stage-specific settings
# API_HOST=0.0.0.0
# API_PORT=8080
