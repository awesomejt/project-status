# Production Environment
# Copy this file to .env.production and update values for production deployment.
# NEVER commit actual .env files with secrets.

# Application environment
APP_ENV=production

# Database: Production PostgreSQL VM
# Replace with actual production PostgreSQL VM connection details
# IMPORTANT: Use environment variable injection in deployment, do not hardcode here
DATABASE_URL=postgresql://prod_user:prod_password@prod-postgres.vm.example.com:5432/project_status_production

